#cloud-config
# /preseed/user-data
# RobloxOS – Subiquity autoinstall (Ubuntu 22.04 LTS)
#
# Format: cloud-init / Subiquity (NIE klasyczny debian preseed).
# Dokumentacja: https://ubuntu.com/server/docs/install/autoinstall-reference
#
# Użycie:
#   Umieść ten plik jako /autoinstall.yaml w katalogu głównym ISO
#   lub jako cipdane do parametru jądra: ds=nocloud;s=file:///...
#
# PRZED UŻYCIEM: zmień hasło poniżej.
# Wygeneruj hash: python3 -c "import crypt; print(crypt.crypt('TWOJE_HASLO'))"
# Lub: openssl passwd -6 'TWOJE_HASLO'

autoinstall:
  version: 1

  # ── Język i lokalizacja ─────────────────────────────────────────────────────
  locale: pl_PL.UTF-8

  keyboard:
    layout: pl
    variant: ""

  # ── Sieć (DHCP na wszystkich interfejsach podczas instalacji) ───────────────
  network:
    network:
      version: 2
      ethernets:
        any:
          match:
            name: "en*"
          dhcp4: true
          dhcp6: false

  # ── Tożsamość systemu ───────────────────────────────────────────────────────
  identity:
    hostname: robloxos
    # ZMIEŃ HASŁO PRZED UŻYCIEM:
    # python3 -c "import crypt,getpass; print(crypt.crypt(getpass.getpass()))"
    password: "$6$ZMIEN_TO$placeholder_hash_wygeneruj_przez_openssl_passwd"
    realname: RobloxOS User
    username: robloxuser

  # ── Strefa czasowa ──────────────────────────────────────────────────────────
  timezone: Europe/Warsaw

  # ── Dysk – cały sda, ext4, bez LVM, bez szyfrowania ────────────────────────
  storage:
    layout:
      name: direct
      # "direct" = prosty podział: /boot/efi (jeśli UEFI) + root
      # Użyj "lvm" jeśli chcesz LVM (nie zalecamy dla konsoli gamingowej)

  # Zamiast "layout" możesz użyć "config" dla pełnej kontroli:
  # storage:
  #   config:
  #     - type: disk
  #       id: disk0
  #       match: {size: largest}
  #       wipe: superblock
  #       ptable: gpt
  #       grub_device: true
  #     - type: partition
  #       id: efi
  #       device: disk0
  #       size: 512M
  #       flag: boot
  #     - type: format
  #       id: efi_fs
  #       volume: efi
  #       fstype: fat32
  #     - type: partition
  #       id: root_part
  #       device: disk0
  #       size: -1   # cała reszta
  #     - type: format
  #       id: root_fs
  #       volume: root_part
  #       fstype: ext4
  #     - type: mount
  #       id: root_mount
  #       device: root_fs
  #       path: /
  #     - type: mount
  #       id: efi_mount
  #       device: efi_fs
  #       path: /boot/efi

  # ── SSH – wyłączony (konsola gamingowa nie potrzebuje SSH) ──────────────────
  ssh:
    install-server: false
    allow-pw: false

  # ── Pakiety instalowane przez Subiquity (apt, wewnątrz chroot) ──────────────
  packages:
    # Środowisko graficzne
    - xorg
    - openbox
    - lightdm
    - picom
    - unclutter
    - wmctrl
    - x11-xserver-utils      # xrandr
    - xdotool
    # Python + launcher
    - python3
    - python3-pip
    - python3-venv
    - python3-pyqt6
    - python3-psutil
    # Przeglądarka
    - chromium-browser
    # Flatpak (Discord, Sober)
    - flatpak
    # Bezpieczeństwo
    - apparmor
    - apparmor-utils
    - apparmor-profiles
    # Narzędzia
    - curl
    - git
    - wget
    - ca-certificates
    - gnupg
    # Audio
    - pulseaudio
    - pavucontrol
    # Czcionki
    - fonts-ubuntu
    - fonts-noto-color-emoji

  # ── Wyłącz niepotrzebne usługi ──────────────────────────────────────────────
  # (realizowane przez late-commands, bo package removal jest pewniejszy po apt)

  # ── Aktualizacje – NIE instaluj automatycznie (konsola ma być stabilna) ─────
  updates: security    # tylko security patches, nie "all"

  # ── Late commands – wykonywane na końcu instalacji, wewnątrz chroot ─────────
  late-commands:
    # Skopiuj chroot-setup.sh do systemu docelowego i uruchom
    - cp /cdrom/robloxos-setup/chroot-setup.sh /target/tmp/chroot-setup.sh
    - chmod +x /target/tmp/chroot-setup.sh
    - curtin in-target --target=/target -- bash /tmp/chroot-setup.sh

    # Wyłącz snapd (niepotrzebny, zajmuje zasoby)
    - curtin in-target --target=/target -- systemctl disable snapd || true
    - curtin in-target --target=/target -- apt-get remove -y snapd || true

    # Wyłącz cloud-init (nie potrzebny po instalacji)
    - curtin in-target --target=/target -- touch /etc/cloud/cloud-init.disabled

    # Wyłącz unattended-upgrades (nie chcemy niespodziewanych update'ów mid-game)
    - curtin in-target --target=/target -- systemctl disable unattended-upgrades || true
    - curtin in-target --target=/target -- apt-get remove -y unattended-upgrades || true

    # Wyłącz plymouth (brak splash screen, szybszy boot)
    - curtin in-target --target=/target -- apt-get remove -y plymouth || true

    # AppArmor – włącz przy starcie
    - curtin in-target --target=/target -- systemctl enable apparmor

    # LightDM – autologin
    - curtin in-target --target=/target -- systemctl enable lightdm

  # ── Reboot po instalacji ────────────────────────────────────────────────────
  shutdown: reboot
